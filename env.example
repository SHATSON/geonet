# GeoNet environment variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Experiment tracking (optional) ───────────────────────────────────────────
WANDB_API_KEY=your_wandb_api_key_here
WANDB_PROJECT=geonet-jmlr
WANDB_ENTITY=your_wandb_username

# ── Data paths ────────────────────────────────────────────────────────────────
# ImageNet root directory (only needed for ImageNet-1K experiments)
IMAGENET_ROOT=/path/to/imagenet

# ── Reproducibility (do not change — matches paper Section 6.4) ───────────────
PYTHONHASHSEED=0
CUBLAS_WORKSPACE_CONFIG=:4096:8

# ── Hardware ──────────────────────────────────────────────────────────────────
# Number of GPUs to use (paper uses 4)
NUM_GPUS=4
